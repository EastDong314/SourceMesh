{
  "name": "sourcemesh",
  "version": "0.1.0",
  "description": "A Playwright CLI based data collection hub for market intelligence",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "cli": "tsx src/cli.ts",
    "collect": "tsx src/cli.ts collect",
    "collect:all": "tsx src/cli.ts collect --all",
    "trigger": "tsx src/cli.ts trigger",
    "status": "tsx src/cli.ts status",
    "list": "tsx src/cli.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "keywords": [
    "playwright",
    "scraper",
    "data-collection",
    "market-intelligence"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.7",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.1",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "playwright": "^1.41.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "prisma": "^5.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pi": {
    "skills": [
      ".pi/skills"
    ]
  }
}
